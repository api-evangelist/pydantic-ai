{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pydantic.dev/schemas/ProjectRead",
  "title": "ProjectRead",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "title": "Id"
    },
    "project_name": {
      "type": "string",
      "title": "Project Name"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "title": "Created At"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Description"
    },
    "organization_name": {
      "type": "string",
      "title": "Organization Name"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public"
      ],
      "title": "Visibility"
    }
  },
  "type": "object",
  "required": [
    "id",
    "project_name",
    "created_at",
    "description",
    "organization_name",
    "visibility"
  ]
}